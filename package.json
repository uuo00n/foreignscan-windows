{
  "name": "foreignscan-front",
  "version": "1.0.0",
  "description": "前端界面，连接Go后端服务",
  "main": "electron/main.js",
  "engines": {
    "node": ">=22.22.1 <23"
  },
  "scripts": {
    "serve": "vue-cli-service serve",
    "build": "vue-cli-service build",
    "test": "vitest",
    "dev:renderer": "vue-cli-service serve --host 127.0.0.1 --port 8080",
    "dev:electron": "wait-on tcp:127.0.0.1:8080 && cross-env NODE_ENV=development electron .",
    "electron:serve": "concurrently -k -n renderer,electron -c cyan,green \"npm run dev:renderer\" \"npm run dev:electron\"",
    "electron:build": "npm run build && electron-builder"
  },
  "dependencies": {
    "axios": "^1.6.2",
    "core-js": "^3.33.3",
    "electron-log": "^5.0.1",
    "node-fetch": "^2.7.0",
    "tdesign-icons-vue-next": "^0.4.1",
    "tdesign-vue-next": "^1.17.2",
    "vue": "^3.3.9",
    "vue-router": "^4.2.5",
    "vuex": "^4.1.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.4",
    "@vue/cli-service": "^5.0.9",
    "@vue/test-utils": "^2.4.6",
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "electron": "^30.5.1",
    "electron-builder": "^24.13.3",
    "html-webpack-plugin": "^5.6.4",
    "jsdom": "^26.1.0",
    "sass": "^1.56.0",
    "sass-loader": "^13.2.0",
    "vitest": "^3.2.4",
    "wait-on": "^8.0.1"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "__npminstall_done": false
}
